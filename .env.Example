# Telegram Bot Token
TELEGRAM_BOT_TOKEN=

# LLM Configuration (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.llm7.io/v1
LLM_MODEL=gpt-4o

# Optional: Embedding model (same or different)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.llm7.io/v1
EMBEDDING_MODEL=gpt-4o

# Paths
DATA_DIR=./data
LOG_LEVEL=INFO

# Limits
MAX_CONVERSATION_HISTORY=20
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200

